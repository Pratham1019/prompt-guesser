# Project configuration
PROJECT_NAME="Prompt Guesser"
API_V1_STR="/api/v1"
ENVIRONMENT="development" # development, testing, production
LOG_LEVEL="INFO"

# Security & CORS
# JSON string of allowed CORS origins
CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]'

# Database Configuration
# Defaulting to an async SQLite database for ease of local development
DATABASE_URL="sqlite+aiosqlite:///./prompt_guesser.db"

# AI API Integration
AI_API_KEY="your-ai-api-key-here"
